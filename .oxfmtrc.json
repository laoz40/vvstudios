{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"printWidth": 100,
	"tabWidth": 2,
	"useTabs": true,
	"semi": true,
	"trailingComma": "all",
	"singleQuote": false,
	"jsxSingleQuote": false,
	"arrowParens": "always",
	"bracketSpacing": true,
	"objectWrap": "preserve",
	"bracketSameLine": true,
	"singleAttributePerLine": true,
	"sortPackageJson": false,
	"ignorePatterns": [
		"dist",
		"node_modules",
		"pnpm-lock.yaml",
		"components/ui/**"
	]
}
