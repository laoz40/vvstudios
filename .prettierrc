{
	"printWidth": 80,
	"tabWidth": 2,
	"useTabs": true,
	"semi": true,
	"trailingComma": "all",
	"singleQuote": false,
	"jsxSingleQuote": false,
	"arrowParens": "always",
	"bracketSpacing": true,
	"objectWrap": "preserve",
	"bracketSameLine": true,
	"singleAttributePerLine": true,
	"plugins": [
		"prettier-plugin-astro",
		"prettier-plugin-svelte",
		"prettier-plugin-tailwindcss"
	],
	"overrides": [
		{
			"files": "*.astro",
			"options": {
				"parser": "astro"
			}
		}
	]
}
