---
import Layout from "../layouts/Layout.astro";
import PricingSection from "../components/pricing/PricingSection.astro";
import { seoPages } from "../content/seo";
import { structuredDataBusiness } from "../content/structuredData";
import { buildBreadcrumbSchema } from "../lib/seo/schema";

const siteUrl = Astro.site ?? new URL(structuredDataBusiness.url);
const pricingStructuredData = buildBreadcrumbSchema(
	[
		{ name: "Home", path: seoPages.home.path },
		{ name: "Pricing", path: seoPages.pricing.path },
	],
	siteUrl,
);
---

<Layout
	title={seoPages.pricing.title}
	description={seoPages.pricing.description}
	canonicalPath={seoPages.pricing.path}
	ogImage={seoPages.pricing.ogImage}
	structuredData={pricingStructuredData}>
	<PricingSection headingLevel="h1" />
</Layout>
