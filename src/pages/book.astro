---
import Layout from "../layouts/Layout.astro";
import BookingStepOne from "../components/book/BookingStepOne.svelte";
import BookingStepTwo from "../components/book/BookingStepTwo.svelte";
import { bookingPageContent } from "../content/booking";
import { seoPages } from "../content/seo";
import { structuredDataBusiness } from "../content/structuredData";
import { buildBreadcrumbSchema } from "../lib/seo/schema";

const siteUrl = Astro.site ?? new URL(structuredDataBusiness.url);
const bookStructuredData = buildBreadcrumbSchema(
	[
		{ name: "Home", path: seoPages.home.path },
		{ name: "Book Studio", path: seoPages.book.path },
	],
	siteUrl,
);
---

<Layout
	title={seoPages.book.title}
	description={seoPages.book.description}
	canonicalPath={seoPages.book.path}
	ogImage={seoPages.book.ogImage}
	structuredData={bookStructuredData}>
	<div class="flex min-h-dvh flex-col gap-18 px-4 pt-24 pb-12 sm:pt-32">
		<div class="text-foreground mx-auto w-full max-w-200">
			<div class="mb-12 space-y-2">
				<p
					class="text-primary text-base font-semibold tracking-widest uppercase">
					{bookingPageContent.stepOne.eyebrow}
				</p>
				<h1 class="text-4xl font-extrabold">
					{bookingPageContent.stepOne.title}
				</h1>
				<p class="text-muted-foreground text-base">
					{bookingPageContent.stepOne.lead}
				</p>
			</div>
			<BookingStepOne client:only="svelte">
				<div
					slot="fallback"
					class="space-y-6"
					aria-hidden="true">
					<div class="bg-muted h-5 w-40 animate-pulse rounded"></div>
					<div class="grid gap-4 md:grid-cols-2">
						<div class="bg-muted h-56 animate-pulse rounded-lg"></div>
						<div class="bg-muted h-56 animate-pulse rounded-lg"></div>
					</div>
					<div class="bg-muted h-5 w-48 animate-pulse rounded"></div>
					<div class="grid gap-4 sm:grid-cols-3">
						<div class="bg-muted h-16 animate-pulse rounded-lg"></div>
						<div class="bg-muted h-16 animate-pulse rounded-lg"></div>
						<div class="bg-muted h-16 animate-pulse rounded-lg"></div>
					</div>
					<div class="bg-muted h-12 w-full animate-pulse rounded-lg"></div>
				</div>
			</BookingStepOne>
		</div>

		<div class="text-foreground mx-auto w-full max-w-200">
			<div class="mb-12 space-y-2">
				<p
					class="text-primary text-base font-semibold tracking-widest uppercase">
					{bookingPageContent.stepTwo.eyebrow}
				</p>
				<h2 class="text-4xl font-extrabold">
					{bookingPageContent.stepTwo.title}
				</h2>
				<p class="text-muted-foreground text-base">
					{bookingPageContent.stepTwo.lead}
				</p>
			</div>
			<BookingStepTwo client:only="svelte">
				<div
					slot="fallback"
					class="space-y-10"
					aria-hidden="true">
					<div class="space-y-6">
						<div class="bg-muted h-6 w-44 animate-pulse rounded"></div>
						<div class="grid gap-8 md:grid-cols-[max-content_minmax(0,1fr)]">
							<div
								class="bg-muted h-90 w-full animate-pulse rounded-lg md:w-80">
							</div>
							<div class="space-y-4">
								<div class="bg-muted h-20 animate-pulse rounded-lg"></div>
								<div class="bg-muted h-20 animate-pulse rounded-lg"></div>
								<div class="bg-muted h-20 animate-pulse rounded-lg"></div>
							</div>
						</div>
					</div>
					<div class="space-y-6">
						<div class="bg-muted h-6 w-40 animate-pulse rounded"></div>
						<div class="space-y-4">
							<div class="bg-muted h-20 animate-pulse rounded-lg"></div>
							<div class="bg-muted h-20 animate-pulse rounded-lg"></div>
							<div class="bg-muted h-28 animate-pulse rounded-lg"></div>
						</div>
					</div>
					<div class="space-y-6">
						<div class="bg-muted h-6 w-52 animate-pulse rounded"></div>
						<div class="space-y-4">
							<div class="bg-muted h-12 animate-pulse rounded-lg"></div>
							<div class="bg-muted h-12 animate-pulse rounded-lg"></div>
							<div class="bg-muted h-12 animate-pulse rounded-lg"></div>
							<div class="bg-muted h-12 animate-pulse rounded-lg"></div>
						</div>
					</div>
				</div>
			</BookingStepTwo>
		</div>
	</div>
</Layout>
