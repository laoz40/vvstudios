---
import Layout from "../layouts/Layout.astro";
import BookingStepOneWrapper from "../components/book/BookingStepOneWrapper.astro";
import BookingStepTwo from "../components/book/BookingStepTwo.svelte";
import { bookingPageContent } from "../content/booking";
---

<Layout title=" | Book Studio">
	<div class="min-h-dvh flex flex-col gap-18 px-4 pt-32 pb-12">
		<div class="mx-auto w-full max-w-200 text-foreground">
			<div class="space-y-2 mb-12">
				<p class="text-primary text-base font-semibold tracking-widest uppercase">
					{bookingPageContent.stepOne.eyebrow}
				</p>
				<h1 class="text-4xl font-extrabold">{bookingPageContent.stepOne.title}</h1>
				<p class="text-base text-muted-foreground">{bookingPageContent.stepOne.lead}</p>
			</div>
			<BookingStepOneWrapper />
		</div>

		<div class="mx-auto w-full max-w-200 text-foreground">
			<div class="space-y-2 mb-12">
				<p class="text-primary text-base font-semibold tracking-widest uppercase">
					{bookingPageContent.stepTwo.eyebrow}
				</p>
				<h1 class="text-4xl font-extrabold">{bookingPageContent.stepTwo.title}</h1>
				<p class="text-base text-muted-foreground">{bookingPageContent.stepTwo.lead}</p>
			</div>
			<BookingStepTwo client:load/>
		</div>
	</div>
</Layout>
