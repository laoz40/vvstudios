---
import FaqSection from "../components/landing/FaqSection.svelte";
import HeroSection from "../components/landing/HeroSection.astro";
import PhotosSection from "../components/photos/PhotosSection.astro";
import PricingSection from "../components/pricing/PricingSection.astro";
import Layout from "../layouts/Layout.astro";
import { Separator } from "$lib/components/ui/separator/index.js";
import {
	faqSectionContent,
	flattenContactFaqAnswer,
} from "../content/landing";
import { photosPageContent } from "../content/photos";
import { structuredDataBusiness } from "../content/structuredData";
import { seoPages } from "../content/seo";
import {
	buildFaqSchema,
	buildLocalBusinessSchema,
	buildOrganizationSchema,
	buildWebSiteSchema,
} from "../lib/seo/schema";

const siteUrl = Astro.site ?? new URL(structuredDataBusiness.url);
const homepageStructuredData = [
	buildWebSiteSchema(structuredDataBusiness.name, siteUrl.toString()),
	buildOrganizationSchema(structuredDataBusiness),
	buildLocalBusinessSchema(structuredDataBusiness),
	buildFaqSchema(
		faqSectionContent.items.map((item) => ({
			question: item.question,
			answer: flattenContactFaqAnswer(item.answerParts),
		})),
	),
];
---

<Layout
	title={seoPages.home.title}
	description={seoPages.home.description}
	canonicalPath={seoPages.home.path}
	ogImage={seoPages.home.ogImage}
	structuredData={homepageStructuredData}>
	<div class="from-background to-popover text-foreground bg-linear-to-b">
		<HeroSection />
	</div>
	<PhotosSection
		images={photosPageContent.homeGalleryImages}
		class="bg-background text-foreground pt-16 pb-12 md:pt-20 md:pb-16"
	/>
	<Separator class="mx-auto max-w-6xl my-6" />
	<PricingSection compact class="bg-background text-foreground pb-12 md:pb-16" />
	<Separator class="mx-auto max-w-6xl my-6" />
	<div class="bg-background text-foreground">
		<FaqSection client:visible compact />
	</div>
</Layout>
