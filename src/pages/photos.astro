---
import PhotosSection from "../components/photos/PhotosSection.astro";
import Layout from "../layouts/Layout.astro";
import { seoPages } from "../content/seo";
import { structuredDataBusiness } from "../content/structuredData";
import { buildBreadcrumbSchema } from "../lib/seo/schema";
const siteUrl = Astro.site ?? new URL(structuredDataBusiness.url);
const photosStructuredData = buildBreadcrumbSchema(
	[
		{ name: "Home", path: seoPages.home.path },
		{ name: "Photos", path: seoPages.photos.path },
	],
	siteUrl,
);
---

<Layout
	title={seoPages.photos.title}
	description={seoPages.photos.description}
	canonicalPath={seoPages.photos.path}
	ogImage={seoPages.photos.ogImage}
	structuredData={photosStructuredData}>
	<PhotosSection headingLevel="h1" />
</Layout>
