---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import micImage from "../assets/mic.jpg";
import FreeTourButton from "../components/shared/FreeTourButton.svelte";
import BookSessionButton from "../components/shared/BookSessionButton.astro";
import {
	contactItems,
	contactPageContent,
	studioAddressHref,
} from "../content/contact";
import { seoPages } from "../content/seo";

const directContactItems = contactItems.filter(
	({ href }) => href !== studioAddressHref,
);
---

<Layout
	title={seoPages.contact.title}
	description={seoPages.contact.description}
	canonicalPath={seoPages.contact.path}
	ogImage={seoPages.contact.ogImage}>
	<section class="px-4 pt-24 pb-12 sm:pt-28 sm:pb-16">
		<div class="mx-auto w-full max-w-2xl">
			<div class="relative overflow-hidden rounded-md shadow-2xl">
				<Image
					src={micImage}
					alt={contactPageContent.studioImageAlt}
					class="h-auto w-full rounded-md object-cover"
					loading="lazy"
					widths={[480, 672, 960, 1344]}
					sizes="(max-width: 672px) 100vw, 672px"
				/>
				<div class="absolute inset-x-0 bottom-0 px-6 py-6 sm:px-8 sm:py-8">
					<h1
						class="text-foreground text-3xl font-bold tracking-tight text-shadow-sm md:text-4xl">
						{contactPageContent.title}
					</h1>

					<dl
						aria-label={contactPageContent.contactInfoAriaLabel}
						class="mt-1 space-y-2 md:mt-6">
						{
							directContactItems.map((item) => (
								<div class="grid gap-1">
									<dt class="text-foreground/70 text-base font-medium md:text-lg">
										{item.label}
									</dt>
									<dd class="min-w-0">
										<a
											class="contact-link text-foreground block text-base font-medium wrap-break-word md:text-lg"
											href={item.href}>
											{item.value}
										</a>
									</dd>
								</div>
							))
						}
					</dl>
				</div>
			</div>
		</div>
		<div class="text-muted-foreground mx-auto mt-6 max-w-2xl text-sm leading-7 sm:text-base">
			<p>
				Reach out if you want to book the studio, ask a question before you lock
				in a session, or get a better feel for how the space works. We work with
				creators, business owners, and teams who want a professional setup
				without a drawn-out booking process.
			</p>
		</div>
		<div class="mx-auto mt-7 md:mt-12 flex max-w-2xl flex-wrap gap-4 sm:gap-3">
			<BookSessionButton
				size="lg"
				class="border-primary min-w-64 flex-1 px-4 py-5 text-base font-semibold sm:px-8"
			/>
			<FreeTourButton
				client:load
				class="min-w-64 flex-1 border-2 px-4 py-5 text-base font-semibold sm:px-8"
			/>
		</div>
	</section>
</Layout>

<style>
	.contact-link {
		text-decoration-color: color-mix(in srgb, var(--primary) 65%, transparent);
		text-underline-offset: 0.22em;
		transition:
			color 160ms ease,
			text-decoration-color 160ms ease;
	}

	.contact-link:hover {
		color: var(--primary);
		text-decoration: underline;
	}

	.contact-link:focus-visible {
		outline: 2px solid var(--primary);
		outline-offset: 3px;
		border-radius: 2px;
	}
</style>
