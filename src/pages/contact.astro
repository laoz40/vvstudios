---
import Layout from "../layouts/Layout.astro";
import ContactCard from "../components/contact/ContactCard.svelte";
import ContactFaqSection from "../components/contact/ContactFaqSection.svelte";
import FreeTourButton from "../components/shared/FreeTourButton.svelte";
import BookSessionButton from "../components/shared/BookSessionButton.astro";
import { Separator } from "$lib/components/ui/separator/index.js";
import {
	type ContactFaqAnswerPart,
	contactEmail,
	contactFaqItems,
	contactItems,
	contactPhone,
	contactPageContent,
	studioAddressHref,
} from "../content/contact";
import { seoPages } from "../content/seo";
import { structuredDataBusiness } from "../content/structuredData";
import { buildBreadcrumbSchema, buildFaqSchema } from "../lib/seo/schema";

const directContactItems = contactItems.filter(
	({ href }) => href !== studioAddressHref,
);
const siteUrl = Astro.site ?? new URL(structuredDataBusiness.url);

const flattenContactFaqAnswer = (
	answerParts: readonly ContactFaqAnswerPart[],
) =>
	answerParts
		.map((part) => {
			switch (part.type) {
				case "text":
					return part.value;
				case "email":
					return contactEmail;
				case "phone":
					return contactPhone;
			}
		})
		.join("")
		.trim();

const contactStructuredData = [
	buildBreadcrumbSchema(
		[
			{ name: "Home", path: seoPages.home.path },
			{ name: "Contact", path: seoPages.contact.path },
		],
		siteUrl,
	),
	buildFaqSchema(
		contactFaqItems.map((item) => ({
			question: item.question,
			answer: flattenContactFaqAnswer(item.answerParts),
		})),
	),
];
---

<Layout
	title={seoPages.contact.title}
	description={seoPages.contact.description}
	canonicalPath={seoPages.contact.path}
	ogImage={seoPages.contact.ogImage}
	structuredData={contactStructuredData}>
	<section class="px-4 pt-24 pb-12 sm:pt-28 sm:pb-16">
		<div class="mx-auto w-full max-w-2xl">
			<ContactCard
				client:media="(hover: hover) and (pointer: fine) and (prefers-reduced-motion: no-preference)"
				title={contactPageContent.title}
				contactInfoAriaLabel={contactPageContent.contactInfoAriaLabel}
				studioImageAlt={contactPageContent.studioImageAlt}
				items={directContactItems}
			/>
		</div>
		<ContactFaqSection client:visible />
		<Separator class="mx-auto my-4 max-w-6xl" />
		<div class="mx-auto mt-7 flex max-w-6xl flex-wrap gap-4 sm:gap-3 md:mt-12">
			<BookSessionButton
				size="lg"
				class="border-primary min-w-64 flex-1 px-4 py-5 text-base font-semibold sm:px-8"
			/>
			<FreeTourButton
				client:load
				class="min-w-64 flex-1 border-2 px-4 py-5 text-base font-semibold sm:px-8"
			/>
		</div>
	</section>
</Layout>
