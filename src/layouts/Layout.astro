---
import DesktopNav from "../components/DesktopNav.svelte";
import Footer from "../components/Footer.svelte";
import MobileNav from "../components/MobileNav.svelte";
import "../styles/global.css";
import "@fontsource-variable/gabarito/wght.css";
import "@fontsource/squada-one";
import "lenis/dist/lenis.css";

const { title } = Astro.props;
const normalizePathname = (pathname: string) => {
	if (pathname.length > 1 && pathname.endsWith("/")) {
		return pathname.slice(0, -1);
	}

	return pathname;
};

const currentPath = normalizePathname(Astro.url.pathname);
const isHome = currentPath === "/";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta
			name="viewport"
			content="width=device-width"
		/>
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/favicon-32x32.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href="/favicon-16x16.png"
		/>
		<link
			rel="manifest"
			href="/site.webmanifest"
		/>
		<meta
			name="generator"
			content={Astro.generator}
		/>
		<title>VV Podcast Studio{title}</title>
	</head>
	<body class="bg-background">
		<!-- Mobile Nav -->
		<div id="mobile-nav-shell">
			<MobileNav
				currentPath={currentPath}
				client:media="(max-width: 767px)"
			/>
		</div>
		<div
			id="site-shell"
			class="flex min-h-screen flex-col">
			<!-- Desktop Nav -->
			{
				// Hydrate only on the home page (for motion) to keep other routes static
				isHome ? (
					<DesktopNav
						currentPath={currentPath}
						client:load
					/>
				) : (
					<DesktopNav currentPath={currentPath} />
				)
			}
			<main>
				<!-- Page Content -->
				<slot />
			</main>
			<!-- Footer -->
			<Footer />
		</div>
		<script>
			import "../scripts/lenis.ts";
		</script>
	</body>
</html>
