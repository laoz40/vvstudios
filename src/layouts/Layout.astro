---
import DesktopNav from "../components/DesktopNav.svelte";
import Footer from "../components/Footer.svelte";
import MobileNav from "../components/MobileNav.svelte";
import "../styles/global.css";
import "@fontsource-variable/montserrat";
import "@fontsource/squada-one";
import "lenis/dist/lenis.css";
import lenisScript from "../scripts/lenis.ts?url";

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
const isHome = currentPath === "/";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link
			rel="icon"
			type="image/svg+xml"
			href="/favicon.svg"
		/>
		<link
			rel="icon"
			href="/favicon.ico"
		/>
		<meta
			name="viewport"
			content="width=device-width"
		/>
		<meta
			name="generator"
			content={Astro.generator}
		/>
		<title>VV Podcast Studio{title}</title>
	</head>
	<body>
		<!-- Mobile Nav -->
		<div id="mobile-nav-shell">
			<MobileNav
				currentPath={currentPath}
				client:media="(max-width: 767px)"
			/>
		</div>
		<div
			id="site-shell"
			class="flex min-h-screen flex-col">
			<!-- Desktop Nav -->
			{
				// Hydrate only on the home page (for motion) to keep other routes static
				isHome ? (
					<DesktopNav currentPath={currentPath} client:load />
				) : (
					<DesktopNav currentPath={currentPath} />
				)
			}
			<main>
				<!-- Page Content -->
				<slot />
			</main>
			<!-- Footer -->
			<Footer />
		</div>
		<script is:inline type="module" src={lenisScript}></script>
	</body>
</html>
