---
import { Button } from "$lib/components/ui/button/index.js";
---

<section
	class="pricing-section section-shell"
	aria-labelledby="pricing-title">
	<div class="section-heading-wrap">
		<p class="eyebrow">Pricing</p>
		<h2 id="pricing-title">Simple Packages for Focused Production.</h2>
	</div>
	<div class="pricing-grid">
		<article class="pricing-card">
			<h3>Starter</h3>
			<p class="price">$180<span>/hour</span></p>
			<ul>
				<li>Single set configuration</li>
				<li>Basic lighting support</li>
				<li>Ideal for small catalogues</li>
			</ul>
		</article>
		<article
			class="pricing-card featured"
			aria-label="Featured plan">
			<p class="badge">Most Popular</p>
			<h3>Studio Day</h3>
			<p class="price">$1,200<span>/day</span></p>
			<ul>
				<li>Full-day studio access</li>
				<li>Priority support on site</li>
				<li>Best for campaigns and launches</li>
			</ul>
		</article>
		<article class="pricing-card">
			<h3>Editorial</h3>
			<p class="price">Custom<span> quote</span></p>
			<ul>
				<li>Large team coordination</li>
				<li>Multi-set creative direction</li>
				<li>Post-production ready workflow</li>
			</ul>
		</article>
	</div>
	<div class="pricing-action-wrap">
		<Button
			href="/book"
			size="lg"
			class="cta-button">
			Reserve Your Slot
		</Button>
		<p class="muted">Transparent rates. No hidden add-ons.</p>
	</div>
</section>

<style>
	.section-shell {
		width: min(1100px, 100% - 2rem);
		margin-inline: auto;
		padding-block: clamp(3.5rem, 8vw, 6rem);
	}

	.pricing-section {
		border-top: 1px solid var(--border);
	}

	.eyebrow {
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--primary);
	}

	.section-heading-wrap {
		display: grid;
		gap: 0.8rem;
		max-width: 42rem;
		margin-bottom: 2rem;
	}

	h2,
	h3 {
		letter-spacing: 0.02em;
		line-height: 1.1;
		font-weight: 700;
	}

	h2 {
		font-size: clamp(1.6rem, 4vw, 2.6rem);
		max-width: 18ch;
	}

	h3 {
		font-size: 1.2rem;
	}

	.pricing-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.pricing-card {
		display: grid;
		gap: 1rem;
		background: var(--card);
		border: 1px solid var(--border);
		padding: 1.5rem;
	}

	.price {
		font-size: clamp(1.7rem, 3vw, 2.3rem);
		font-weight: 700;
		line-height: 1;
		color: var(--foreground);
	}

	.price span {
		font-size: 1rem;
		font-weight: 500;
		color: var(--muted-foreground);
	}

	.pricing-card ul {
		display: grid;
		gap: 0.4rem;
		padding-left: 1rem;
	}

	.pricing-card li {
		line-height: 1.65;
		color: var(--muted-foreground);
	}

	.pricing-card li::marker {
		color: var(--primary);
	}

	.featured {
		border-color: var(--primary);
		box-shadow: 0 0 0 1px color-mix(in srgb, var(--primary) 45%, transparent);
	}

	.badge {
		display: inline-block;
		width: fit-content;
		padding: 0.2rem 0.65rem;
		border: 1px solid var(--primary);
		color: var(--primary);
		font-size: 0.76rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.pricing-action-wrap {
		display: grid;
		justify-items: center;
		gap: 0.8rem;
		margin-top: 1.8rem;
	}

	.cta-button {
		font-weight: 700;
		background: var(--primary);
		color: var(--primary-foreground);
		border: 1px solid var(--primary);
	}

	.cta-button:hover {
		background: color-mix(in srgb, var(--primary) 86%, white);
		border-color: color-mix(in srgb, var(--primary) 86%, white);
	}

	.cta-button:focus-visible {
		outline: 2px solid var(--ring);
		outline-offset: 2px;
	}

	.muted {
		font-size: 0.95rem;
		line-height: 1.65;
		color: var(--muted-foreground);
	}

	@media (max-width: 900px) {
		.pricing-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
