---
import { Button } from "$lib/components/ui/button/index.js";
import { heroContent } from "../../content/landing";
import MapPinIcon from "./MapPinIcon.svelte";
---

<section
	class="relative isolate flex min-h-dvh items-center"
	aria-labelledby="home-hero-title">
	<div
		class="absolute inset-0 -z-20 bg-[url('/images/hero-monochrome.jpg')] bg-cover bg-center brightness-75 grayscale"
		aria-hidden="true">
	</div>
	<div
		class="from-background/75 via-background/45 to-background/80 absolute inset-0 -z-10 bg-linear-to-br">
	</div>
	<div class="relative container mx-auto grid gap-4 px-4 py-24 mt-60 mb-10 md:py-32">
		<p class="text-primary m-0 text-sm font-semibold tracking-widest uppercase">
			{heroContent.eyebrow}
		</p>
		<h1
			class="text-foreground m-0 max-w-sm text-4xl leading-tight text-balance font-bold tracking-tight md:text-6xl md:max-w-xl">
			{heroContent.title}
		</h1>
		<p
			class="text-muted-foreground m-0 max-w-sm text-base text-pretty leading-relaxed md:max-w-xl">
			{heroContent.lead}
		</p>
		<div class="mt-4 flex w-full flex-wrap gap-3 md:mt-12">
			<Button
				href={heroContent.primaryCtaHref}
				size="lg"
				class="border-primary text-base flex-1 border-2 px-8 py-5 font-semibold transition-transform duration-200 ease-out hover:-translate-y-px hover:border-[#d9ac00] md:flex-none">
				{heroContent.primaryCtaLabel}
			</Button>
			<Button
				href={heroContent.secondaryCtaHref}
				variant="outline"
				size="lg"
				class="text-foreground text-base flex-1 border-2 px-8 py-5 font-semibold transition-transform duration-200 ease-out hover:-translate-y-px md:flex-none">
				{heroContent.secondaryCtaLabel}
			</Button>
		</div>
	</div>
	<a
		class="text-muted-foreground hover:text-foreground focus-visible:outline-ring absolute bottom-4 left-1/2 grid -translate-x-1/2 justify-items-center no-underline transition focus-visible:rounded focus-visible:outline-2 focus-visible:outline-offset-4 md:bottom-5"
		href="#info-section"
		aria-label={heroContent.scrollAriaLabel}>
		<span class="text-2xl leading-none font-light">↓</span>
	</a>
	<div
		class="text-muted-foreground absolute bottom-16 left-0 inline-flex items-center gap-2 px-4 py-2 text-sm font-normal md:left-auto md:right-8 md:text-base">
		<MapPinIcon class="text-primary" />
		<span class="text-muted-foreground">{heroContent.address}</span>
	</div>
</section>
