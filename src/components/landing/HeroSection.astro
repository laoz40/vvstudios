---
import heroDesktop from "../../assets/bg/landing.webp";
import heroMobile from "../../assets/bg/mobile.webp";
import FreeTourButton from "../shared/FreeTourButton.svelte";
import BookSessionButton from "../shared/BookSessionButton.astro";
import { heroContent } from "../../content/landing";
import { studioAddressHref } from "../../content/contact";
import MapPinIcon from "./MapPinIcon.svelte";
import { Button } from "$lib/components/ui/button";
---

<section
	class="relative isolate flex min-h-dvh items-center"
	data-hero-root
	aria-labelledby="home-hero-title">
	<div
		class="absolute inset-0 -z-20 overflow-hidden"
		aria-hidden="true">
		<picture>
			<source
				media="(min-width: 768px)"
				srcset={heroDesktop.src}
			/>
			<img
				src={heroMobile.src}
				alt={heroContent.desktopBackgroundAlt}
				loading="eager"
				decoding="sync"
				fetchpriority="high"
				class="h-full w-full object-cover brightness-65"
			/>
		</picture>
	</div>
	<div
		class="from-background/75 via-background/45 to-background/80 absolute inset-0 -z-10 bg-linear-to-br">
	</div>
	<div
		class="relative container mx-auto mt-80 mb-10 grid gap-4 px-6 py-24 sm:mt-36 sm:px-8 lg:mt-60 lg:px-10 md:py-32">
		<div
			data-hero-fade="content"
			class="flex flex-col gap-3 md:block">
			<p
				class="text-primary m-0 text-sm font-semibold tracking-widest uppercase">
				{heroContent.eyebrow}
			</p>
			<h1
				id="home-hero-title"
				class="text-foreground m-0 max-w-sm text-4xl leading-tight font-bold tracking-tight text-balance md:max-w-xl md:text-6xl"
			>
				{heroContent.title}
			</h1>
			<p
				class="text-muted-foreground mt-4 max-w-sm text-base leading-relaxed text-pretty md:max-w-xl">
				{heroContent.lead}
			</p>
			<div class="mt-6 flex w-full flex-wrap gap-3 md:mt-12">
				<BookSessionButton
					size="lg"
					class="border-primary flex-1 border-2 px-8 py-5 text-base font-semibold transition-transform duration-200 ease-out hover:-translate-y-px hover:border-[#d9ac00] md:flex-none"
				/>
				<FreeTourButton
					client:load
					label={heroContent.secondaryCtaLabel}
					variant="outline"
					size="lg"
					class="text-foreground flex-1 border-2 px-8 py-5 text-base font-semibold transition-transform duration-200 ease-out hover:-translate-y-px md:flex-none"
				/>
			</div>
		</div>
	</div>
	<div
		data-hero-fade="address"
		class="text-muted-foreground absolute bottom-8 left-0 inline-flex items-center gap-2 px-4 py-2 text-sm font-normal md:right-8 md:left-auto md:text-base">
		<MapPinIcon class="text-primary" />
		<Button
			variant="link"
			href={studioAddressHref}
		class="px-0">
			{heroContent.address}
		</Button>
	</div>
</section>

<style>
	/* Start hidden so motion can animate in cleanly. */
	[data-hero-fade="content"] {
		opacity: 0;
		transform: translateY(12px);
		filter: blur(10px);
	}

	[data-hero-fade="address"] {
		opacity: 0;
	}

	[data-hero-title] {
		text-shadow: 0 3px 18px rgba(0, 0, 0, 0.7), 0 1px 2px rgba(0, 0, 0, 0.85);
	}
</style>

<noscript>
	<style>
		/* Show hero content when JS is off. */
		[data-hero-fade] {
			opacity: 1 !important;
		}

		[data-hero-fade="content"] {
			transform: translateY(0) !important;
			filter: blur(0) !important;
		}
	</style>
</noscript>

<script>
	import {
		animate,
		type AnimationOptions,
		type DOMKeyframesDefinition,
	} from "motion";

	const heroRoots = document.querySelectorAll("[data-hero-root]");
	const prefersReducedMotion = window.matchMedia(
		"(prefers-reduced-motion: reduce)",
	).matches;

	for (const heroRoot of heroRoots) {
		const content = heroRoot.querySelector('[data-hero-fade="content"]');
		const address = heroRoot.querySelector('[data-hero-fade="address"]');

		if (
			!(content instanceof HTMLElement) ||
			!(address instanceof HTMLElement)
		) {
			continue;
		}

		if (prefersReducedMotion) {
			content.style.opacity = "1";
			content.style.transform = "translateY(0)";
			content.style.filter = "blur(0px)";
			address.style.opacity = "1";
			continue;
		}

		const contentKeyframes: DOMKeyframesDefinition = {
			opacity: [0, 1],
			transform: ["translateY(12px)", "translateY(0px)"],
			filter: ["blur(6px)", "blur(0px)"],
		};
		const addressKeyframes: DOMKeyframesDefinition = {
			opacity: [0, 1],
			filter: ["blur(6px)", "blur(0px)"],
		};
		const contentOptions: AnimationOptions = {
			duration: 0.75,
			ease: "easeOut",
		};
		const addressOptions: AnimationOptions = {
			duration: 0.75,
			delay: 0.15,
			ease: "easeOut",
		};

		animate(content, contentKeyframes, contentOptions);
		animate(address, addressKeyframes, addressOptions);
	}
</script>
