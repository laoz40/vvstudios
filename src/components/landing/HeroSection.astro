---
import { Button } from "$lib/components/ui/button/index.js";
import MapPinIcon from "./MapPinIcon.svelte";

const eyebrow = "From Vertigo Visuals";
const heroTitle = "The Only Pro Studio in South West Sydney";
const lead =
	"Professional production spaces for podcasts, e-commerce, and campaign shoots.";
---

<section
	class="relative isolate flex min-h-dvh items-center"
	aria-labelledby="home-hero-title">
	<div
		class="absolute inset-0 -z-20 bg-[url('/images/hero-monochrome.jpg')] bg-cover bg-center brightness-75 grayscale"
		aria-hidden="true">
	</div>
	<div
		class="from-background/75 via-background/45 to-background/80 absolute inset-0 -z-10 bg-linear-to-br">
	</div>
	<div class="relative container mx-auto grid gap-4 px-4 py-24 md:py-32">
		<p class="text-primary m-0 text-sm font-semibold tracking-widest uppercase">
			{eyebrow}
		</p>
		<h1
			class="text-foreground m-0 max-w-3xl text-4xl leading-tight font-bold tracking-tight md:text-6xl">
			{heroTitle}
		</h1>
		<p
			class="text-muted-foreground m-0 max-w-3xl text-base leading-relaxed font-medium">
			{lead}
		</p>
		<div class="mt-12 flex w-full flex-wrap gap-3">
			<Button
				href="/book"
				size="lg"
				class="border-primary border-2 px-8 py-5 font-semibold md:flex-none">
				Book session
			</Button>
			<Button
				href="/contact"
				variant="outline"
				size="lg"
				class="border-neutral-300! bg-secondary/60 text-foreground hover:bg-accent/80 flex-1 border-2 px-8 py-5 font-semibold md:flex-none">
				Get free tour
			</Button>
		</div>
	</div>
	<a
		class="text-muted-foreground hover:text-foreground focus-visible:outline-ring absolute bottom-4 left-1/2 grid -translate-x-1/2 justify-items-center text-xs font-medium uppercase no-underline transition focus-visible:rounded focus-visible:outline-2 focus-visible:outline-offset-4 md:bottom-5"
		href="#info-section"
		aria-label="Scroll to information section">
		<span class="text-3xl leading-none font-medium">↓</span>
	</a>
	<div
		class="text-muted-foreground absolute right-0 bottom-16 inline-flex items-center gap-2 px-4 py-2 text-sm font-normal md:right-8 md:text-base">
		<MapPinIcon class="text-primary" />
		<span class="text-muted-foreground font-medium"
			>23 Fields Rd, Macquarie Fields NSW 2564</span
		>
	</div>
</section>
