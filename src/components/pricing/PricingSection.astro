---
import BookSessionButton from "../shared/BookSessionButton.astro";
import { pricingPageContent } from "../../content/pricing";

export type PricingSectionProps = {
	headingLevel?: "h1" | "h2";
	class?: string;
	compact?: boolean;
};

const {
	headingLevel = "h2",
	class: className,
	compact = false,
} = Astro.props satisfies PricingSectionProps;

const HeadingTag = headingLevel;
---

<section
	class:list={[
		"px-4 pb-16 sm:pb-20",
		compact ? "pt-8 md:pt-12" : "pt-28 md:pt-32",
		className,
	]}>
	<div class="mx-auto flex w-full max-w-6xl flex-col gap-8">
		<div class="max-w-3xl space-y-4 pb-2">
			<HeadingTag class="text-2xl leading-none font-bold md:text-4xl">
				{pricingPageContent.title}
			</HeadingTag>
			<p class="text-muted-foreground text-sm text-pretty leading-7 sm:text-base">
				{pricingPageContent.lead}
			</p>
		</div>

		<div class="grid gap-5 lg:grid-cols-3">
			{pricingPageContent.sessions.map((session) => (
				<article class="border-border bg-card flex h-full flex-col rounded-lg border p-4 sm:p-6">
					<div class="flex flex-1 flex-col gap-4">
						<div class="space-y-2">
							<div class="flex items-center justify-between gap-4">
								<h2 class="text-foreground text-lg sm:text-lg">{session.label}</h2>
								{session.isMostPopular && (
									<span class="bg-primary text-primary-foreground inline-flex items-center rounded-md px-3 py-1 text-xs font-bold tracking-wide uppercase">
										Most popular
									</span>
								)}
							</div>
							<p class="text-4xl leading-none sm:text-4xl">{session.price}</p>
							<div class="min-h-6">
								{session.savings && (
									<div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm">
										<p class="text-muted-foreground">
											<span class="line-through">{session.baseRatePrice}</span>
											<span>standard rate</span>
										</p>
										<p class="text-primary font-semibold">{session.savings}</p>
									</div>
								)}
								{!session.savings && (
									<p class="text-muted-foreground text-sm">Standard rate</p>
								)}
							</div>
						</div>

						<p class="text-muted-foreground text-sm leading-relaxed sm:text-base">
							{session.description}
						</p>

						<div class="mt-auto pt-2">
							<BookSessionButton class="w-full justify-center font-medium text-base" />
						</div>
					</div>
				</article>
			))}
		</div>

		<div class="space-y-4 mt-8">
			<section class="space-y-4">
				<div class="max-w-3xl space-y-4">
					<h3 class="text-xl leading-none font-bold md:text-2xl">
						{pricingPageContent.addOnsTitle}
					</h3>
					<p class="text-muted-foreground text-sm text-pretty leading-7 sm:text-base">
						{pricingPageContent.addOnsLead}
					</p>
				</div>

				<div class="grid gap-4 md:grid-cols-3">
					{pricingPageContent.addOns.map((addOn) => (
						<div class="border-border bg-card flex h-full flex-col gap-3 rounded-lg border p-5">
							<div class="flex items-start justify-between gap-4">
								<h3 class="text-base font-semibold">{addOn.label}</h3>
								<p class="text-primary text-base font-semibold">{addOn.price}</p>
							</div>
							<p class="text-muted-foreground text-sm leading-relaxed sm:text-base">
								{addOn.description}
							</p>
						</div>
					))}
				</div>
			</section>
		</div>
	</div>
</section>
